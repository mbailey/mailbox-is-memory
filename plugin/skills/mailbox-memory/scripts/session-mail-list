#!/usr/bin/env bash
# session-mail-list — low-context SCAN of a maildir: one line per message,
# sender + subject only, unread marked. The `list` half of r07's progressive-
# disclosure read interface (COMS-86 do-010 / design §6 D8). Costs a few tokens
# per message — nothing here slurps a body into context; that is `read`'s job.
#
#   session mail list <me> [--unread] [--from MATCH] [--subject-match RE] \
#                     [--root DIR]
#
# Output is a stable, chronologically-sorted, 1-based index; `session mail read
# <me> <n>` opens the nth line of the SAME ordering. Reading is non-destructive
# (peek) — listing never claims mail, so it never disturbs `session mail wait`'s
# exactly-once new/->cur/ claim.
#
# Maildir resolution is CASE-INSENSITIVE (design §5.7): the canonical on-disk
# form is lowercase (what send/wait fold to), but a legacy mixed-case box is
# matched too. Root defaults to ~/.mail/agents; override with --root or
# $SESSION_MAIL_ROOT.
set -euo pipefail
die() { echo "session mail list: $*" >&2; exit 2; }
lc()  { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

ROOT="${SESSION_MAIL_ROOT:-$HOME/.mail/agents}"
ME=""; UNREAD_ONLY=0; FROM_MATCH=""; SUBJ_MATCH=""

[ $# -ge 1 ] || die "missing <me>  (usage: session mail list <me> [--unread] [--from M] [--root DIR])"
case "$1" in -h|--help) sed -n '2,18p' "$0"; exit 0 ;; esac
ME="$1"; shift
while [ $# -gt 0 ]; do
  case "$1" in
    --unread|-u)     UNREAD_ONLY=1; shift ;;
    --from)          FROM_MATCH="$2"; shift 2 ;;
    --subject-match) SUBJ_MATCH="$2"; shift 2 ;;
    --root)          ROOT="$2"; shift 2 ;;
    -h|--help)       sed -n '2,18p' "$0"; exit 0 ;;
    *)               die "unknown flag: $1" ;;
  esac
done

# Case-insensitive maildir resolution (§5.7). Prefer the canonical lowercase box
# (what send/wait write); fall back to a legacy mixed-case directory already on
# disk; else return the lowercase path (an as-yet-unused, empty box).
resolve_mbox() {
  local me="$1" lc_me d b
  lc_me="$(lc "$me")"
  if [ -d "$ROOT/$lc_me" ]; then printf '%s\n' "$ROOT/$lc_me"; return 0; fi
  if [ -d "$ROOT" ]; then
    for d in "$ROOT"/*/; do
      [ -d "$d" ] || continue
      b="$(basename "$d")"
      [ "$(lc "$b")" = "$lc_me" ] && { printf '%s\n' "${d%/}"; return 0; }
    done
  fi
  printf '%s\n' "$ROOT/$lc_me"
}
MBOX="$(resolve_mbox "$ME")"

# Deterministic enumeration shared verbatim with session-mail-read so an index
# from `list` opens the same message in `read`. Emits: <state>\t<basekey>\t<path>
# — N=unread (new/), S=seen (cur/). Sort key is the maildir unique name (epoch-
# prefixed ⇒ chronological), with cur/'s :2,<flags> info suffix stripped.
enumerate() {
  local m base
  {
    if [ -d "$MBOX/new" ]; then
      for m in "$MBOX"/new/*; do
        [ -f "$m" ] || continue
        printf 'N\t%s\t%s\n' "$(basename "$m")" "$m"
      done
    fi
    if [ -d "$MBOX/cur" ]; then
      for m in "$MBOX"/cur/*; do
        [ -f "$m" ] || continue
        base="$(basename "$m")"; base="${base%%:*}"
        printf 'S\t%s\t%s\n' "$base" "$m"
      done
    fi
  } | sort -t "$(printf '\t')" -k2,2
}

# Pull a single header value (first line, case-insensitive name). Header block
# ends at the first blank line; continuation lines are not unfolded (agent mail
# is single-line) — good enough for a scan.
hdr() {
  awk -v h="$(lc "$1")" '
    /^\r?$/ { exit }
    { low = tolower($0)
      if (index(low, h ":") == 1) { line=$0; sub(/^[^:]*:[ \t]*/,"",line); sub(/\r$/,"",line); print line; exit } }
  ' "$2"
}

# Truncate a display field to keep the scan low-context.
trunc() { local s="$1" n="$2"; if [ "${#s}" -gt "$n" ]; then printf '%s…' "${s:0:$((n-1))}"; else printf '%s' "$s"; fi; }

idx=0; shown=0; unread=0
lines=""
while IFS="$(printf '\t')" read -r state _key path; do
  [ -n "${path:-}" ] || continue
  idx=$((idx+1))                                  # index spans ALL messages (list/read parity)
  [ "$state" = "N" ] && unread=$((unread+1))
  [ "$UNREAD_ONLY" -eq 1 ] && [ "$state" != "N" ] && continue
  from="$(hdr From "$path")";    from="${from:-(unknown)}"
  subj="$(hdr Subject "$path")"; subj="${subj:-(no subject)}"
  if [ -n "$FROM_MATCH" ]; then printf '%s' "$from" | grep -iq "$FROM_MATCH" || continue; fi
  if [ -n "$SUBJ_MATCH" ]; then printf '%s' "$subj" | grep -iEq "$SUBJ_MATCH" || continue; fi
  mark=" "; [ "$state" = "N" ] && mark="*"
  lines+="$(printf '%3d  %s  %-24s  %s' "$idx" "$mark" "$(trunc "$from" 24)" "$(trunc "$subj" 56)")"$'\n'
  shown=$((shown+1))
done < <(enumerate)

name="$(basename "$MBOX")"
if [ "$idx" -eq 0 ]; then
  echo "${name}: no messages"
  exit 0
fi
printf '%s: %d message%s (%d unread)%s\n' "$name" "$idx" "$([ "$idx" -eq 1 ] || echo s)" "$unread" \
  "$([ "$UNREAD_ONLY" -eq 1 ] && echo ' — showing unread' || true)"
printf '%s' "$lines"
